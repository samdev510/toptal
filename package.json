{
  "name": "bookshop",
  "version": "1.0.0",
  "private": true,
  "description": "bookshop api",
  "scripts": {
    "dev": "pnpm --filter @bookshop/api dev",
    "build": "pnpm -r build",
    "start": "pnpm --filter @bookshop/api start",
    "lint": "eslint packages/",
    "lint:fix": "eslint packages/ --fix",
    "format": "prettier --write \"packages/**/*.{ts,json}\"",
    "test": "pnpm --filter @bookshop/api test",
    "typecheck": "pnpm -r typecheck",
    "db:migrate": "pnpm --filter @bookshop/api db:migrate",
    "db:seed": "pnpm --filter @bookshop/api db:seed",
    "db:studio": "pnpm --filter @bookshop/api db:studio"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
